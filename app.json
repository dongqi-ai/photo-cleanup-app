{
  "expo": {
    "name": "Photo Cleanup",
    "slug": "photo-cleanup-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.newfieldstech.photocleanup",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Photo Cleanup needs access to your photo library to help you find and review duplicate or burst-like photos. Photos are processed entirely on-device and never uploaded anywhere.",
        "NSPhotoLibraryAddUsageDescription": "Photo Cleanup needs permission to delete photos you have reviewed and approved for deletion."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.newfieldstech.photocleanup",
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-media-library",
      [
        "expo-file-system",
        {
          "photosPermission": "Photo Cleanup accesses your photos to analyze duplicates locally on your device."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "photo-cleanup"
  }
}
